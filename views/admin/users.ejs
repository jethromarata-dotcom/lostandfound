<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Users — Admin</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../_nav') %>
  <main>
    <a href="/admin" class="back-link">← Admin Panel</a>
    <div class="page-header"><h1>Registered Students</h1></div>
    <div class="table-card">
      <table>
        <thead><tr><th>Username</th><th>Email</th><th>Role</th><th>Joined</th></tr></thead>
        <tbody>
          <% users.forEach(user => { %>
          <tr>
            <td><strong><%= user.username %></strong></td>
            <td style="color:var(--text-dim)"><%= user.email %></td>
            <td><span class="badge badge-active"><%= user.role %></span></td>
            <td style="font-size:0.78rem;color:var(--text-dim)"><%= user.createdAt.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>
</body>
</html>
