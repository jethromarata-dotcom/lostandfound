<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Item — Lost & Found</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../_nav') %>
  <main>
    <a href="/items/<%= item._id %>" class="back-link">← Back to item</a>
    <div class="page-header">
      <h1>Edit Item</h1>
      <p>Update the details for: <strong><%= item.name %></strong></p>
    </div>

    <div class="form-card">
      <form action="/items/<%= item._id %>/update" method="POST" enctype="multipart/form-data">

        <div class="form-group">
          <label>Item Type</label>
          <div class="type-toggle">
            <input type="radio" name="type" id="type-lost" value="lost" <%= item.type==='lost'?'checked':'' %>>
            <label for="type-lost">🔴 Lost</label>
            <input type="radio" name="type" id="type-found" value="found" <%= item.type==='found'?'checked':'' %>>
            <label for="type-found">🟢 Found</label>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Item Name *</label>
            <input type="text" name="name" required value="<%= item.name %>">
          </div>
          <div class="form-group">
            <label>Category *</label>
            <select name="category" required>
              <% CATEGORIES.forEach(c => { %><option value="<%= c %>" <%= item.category===c?'selected':'' %>><%= c %></option><% }) %>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>Color</label>
            <input type="text" name="color" value="<%= item.color||'' %>">
          </div>
          <div class="form-group">
            <label>Date Lost / Found *</label>
            <input type="date" name="dateLostFound" required value="<%= item.dateLostFound.toISOString().split('T')[0] %>">
          </div>
        </div>

        <div class="form-group">
          <label>Location *</label>
          <input type="text" name="location" required value="<%= item.location %>">
        </div>

        <div class="form-group">
          <label>Description *</label>
          <textarea name="description" required><%= item.description %></textarea>
        </div>

        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="active" <%= item.status==='active'?'selected':'' %>>Active</option>
            <option value="claimed" <%= item.status==='claimed'?'selected':'' %>>Claimed</option>
            <option value="resolved" <%= item.status==='resolved'?'selected':'' %>>Resolved</option>
          </select>
        </div>

        <div class="form-group">
          <label>Replace Photo</label>
          <% if (item.image) { %>
            <img src="/uploads/<%= item.image %>" style="display:block;max-height:120px;border-radius:6px;margin-bottom:0.5rem;object-fit:cover">
          <% } %>
          <input type="file" name="image" accept="image/jpeg,image/png,image/webp">
          <p class="hint">Upload a new photo to replace the current one.</p>
        </div>

        <div class="form-group">
          <label>Contact Email</label>
          <input type="email" name="contactEmail" value="<%= item.contactEmail||'' %>">
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <a href="/items/<%= item._id %>" class="btn btn-ghost">Cancel</a>
        </div>
      </form>
    </div>
  </main>
</body>
</html>
